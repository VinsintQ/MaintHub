{
  "info": {
    "_postman_id": "5b684f8f-8ab7-4f2b-bf03-4be8e3f7f5d1",
    "name": "RepairFlow API",
    "description": "Postman collection for the RepairFlow Spring Boot backend. Run Login to save jwtToken automatically from LoginResponse.message.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Staff User",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"Staff User\",\n  \"emailAddress\": \"{{staffEmail}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/users/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.message && !data.message.startsWith('Error')) {",
                  "  pm.collectionVariables.set('jwtToken', data.message);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/users/login"
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/users/register/verify?token={{verifyToken}}"
          }
        },
        {
          "name": "Request Password Reset",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailAddress\": \"{{loginEmail}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/users/resetPassword"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPass\": \"{{password}}\",\n  \"newPass\": \"{{newPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/users/change-password"
          }
        },
        {
          "name": "Soft Delete User",
          "request": {
            "method": "PUT",
            "header": [],
            "url": "{{baseUrl}}/auth/users/{{userId}}/soft-delete"
          }
        },
        {
          "name": "Promote User To Admin",
          "request": {
            "method": "PUT",
            "header": [],
            "url": "{{baseUrl}}/auth/users/{{userId}}/promote"
          }
        }
      ]
    },
